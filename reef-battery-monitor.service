[Unit]
Description=Reef Battery Monitor (INA226/Victron + MQTT)
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/reef-battery
ExecStart=/usr/bin/python3 /home/pi/reef-battery/main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
